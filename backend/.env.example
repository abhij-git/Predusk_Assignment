# Copy to backend/.env — variables load from the backend/ folder (not your shell cwd).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docflow
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docflow
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Optional; default is backend/uploads (absolute path under this repo)
# UPLOAD_DIR=/path/to/uploads
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
